# Home Lab Media Server - Environment Configuration
# Change these paths when migrating to new hardware

# User/Group IDs for file permissions (run `id` on your host to find these)
# On Windows with Docker Desktop this usually doesn't matter, but 1000/1000 is a safe default.
PUID=1000
PGID=1000

# Timezone (https://en.wikipedia.org/wiki/List_of_tz_database_time_zones)
TZ=America/Mexico_City

# Base paths - change these when migrating to new hardware
CONFIG_PATH=./config
MEDIA_PATH=./media

# Service ports (change if you have conflicts)
JELLYFIN_PORT=8096
RADARR_PORT=7878
PROWLARR_PORT=9696
QBITTORRENT_PORT=8080
BAZARR_PORT=6767

